<?xml version="1.0"?>
<PropertyList>
  <path>asi700kt.ac</path>

  <effect>
    <inherits-from>Aircraft/daVinci_B-26B/Models/effects/interior</inherits-from>
    <object-name>Face</object-name>
    <object-name>needle1</object-name>
  </effect>

  <animation>
    <type>material</type>
    <object-name>Face</object-name>
    <object-name>needle1</object-name>
    <emission>
      <factor-prop>/sim/model/rendering/relative-instrument-luminosity</factor-prop>
      <red>   0.20</red>
      <green> 0.60 </green>
      <blue>  0.65 </blue>
    </emission>
    <condition>
      <property>/sim/model/rendering/relative-instrument-luminosity</property>
      <equals><property>/systems/electrical/on</property><value>1</value></equals>
    </condition>
  </animation>
  <animation>
    <type>material</type>
    <object-name>Face</object-name>
    <object-name>needle1</object-name>
    <emission>
      <factor-prop>/sim/model/rendering/relative-cabin-luminosity</factor-prop>
      <red>.04</red>
      <green>.14</green>
      <blue>.14</blue>
    </emission>
    <condition>
      <not><property>/sim/model/rendering/relative-instrument-luminosity</property></not>
      <equals><property>/systems/electrical/on</property><value>1</value></equals>
    </condition>
  </animation>

  <animation>
    <type>rotate</type>
    <object-name>needle1</object-name>
    <property>/instrumentation/airspeed-indicator/true-speed-kt</property>
    <interpolation>
      <entry><ind>0</ind><dep>0</dep></entry>
      <entry><ind>55</ind><dep>1</dep></entry>
      <entry><ind>745</ind><dep>359</dep></entry>
      <entry><ind>1000</ind><dep>359</dep></entry>
    </interpolation>
    <center>
      <x-m>0</x-m>
      <y-m>0</y-m>
      <z-m>0</z-m>
    </center>
    <axis>
      <x>-1</x>
      <y>0</y>
      <z>0</z>
    </axis>
  </animation>

  <animation>
    <type>pick</type>
    <object-name>Face</object-name>
    <visible>true</visible>
    <hovered>
      <binding>
        <command>set-tooltip</command>
        <tooltip-id>tooltip-clock</tooltip-id>
        <label>indicated speed : %d kt</label>
        <property>/instrumentation/airspeed-indicator/true-speed-kt</property>
      </binding>
    </hovered>
  </animation>

</PropertyList>


