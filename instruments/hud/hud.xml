<?xml version="1.0" encoding="utf-8"?>
<!--
################################################################################
#
#                               HUD CONFIGURATION
#
################################################################################

see :
- http://wiki.flightgear.org/Head-up_display
- http://wiki.flightgear.org/Canvas_HUD
-->

<PropertyList>

  <enable3d>true</enable3d>
  <!--
================================================================================
                                                                          LADDER
================================================================================
-->
  <ladder>
    <name>Pitch Ladder</name>
    <type>pitch</type>
    <x>-40</x>
    <y>-10</y>
    <width>80</width>
    <height>20</height>
    <roll-input>
      <property>/orientation/roll-deg</property>
    </roll-input>
    <pitch-input>
      <property>/orientation/pitch-deg</property>
    </pitch-input>
    <compression-factor>10</compression-factor>
    <display-span>18</display-span>
    <divisions>5</divisions>
    <screen-hole>6</screen-hole>
    <tick-length>2</tick-length>
    <zero-bar-overlength>100</zero-bar-overlength>
    <enable-dive-bar-angle>true</enable-dive-bar-angle>
    <enable-dynamic-origin>false</enable-dynamic-origin>
    <enable-fuselage-ref-line>true</enable-fuselage-ref-line>
    <enable-target-spot>false</enable-target-spot>
    <enable-target-markers>true</enable-target-markers>
    <enable-velocity-vector>true</enable-velocity-vector>
    <enable-drift-marker>false</enable-drift-marker>
    <enable-alpha-bracket>false</enable-alpha-bracket>
    <enable-energy-marker>true</enable-energy-marker>
    <enable-climb-dive-marker>false</enable-climb-dive-marker>
    <enable-glide-slope-marker>true</enable-glide-slope-marker>
    <glide-slope>1.0</glide-slope>
    <enable-energy-worm>true</enable-energy-worm>
    <enable-waypoint-marker>false</enable-waypoint-marker>
    <enable-zenith>false</enable-zenith>
    <enable-nadir>false</enable-nadir>
  </ladder>


  <!--
================================================================================
                                                             TURN BANK INDICATOR
================================================================================
-->
  <turn-bank-indicator>
    <name>Turn Indicator</name>
    <x>-80</x>
    <y>-140</y>
    <width>160</width>
    <height>160</height>
    <bank-input>
      <property>/orientation/roll-deg</property>
    </bank-input>
    <sideslip-input>
      <property>/orientation/side-slip-deg</property>
    </sideslip-input>
    <bank-scale>true</bank-scale>
    <option>top</option>
  </turn-bank-indicator>

  <!--
================================================================================
                                                                         HEADING
================================================================================
-->
  <label>
    <name>Heading Label</name>
    <x>-9</x>
    <y>80</y>
    <width>18</width>
    <height>10</height>
    <input>
      <property>/orientation/heading-deg</property>
    </input>
    <format>%3.0f</format>
    <halign>center</halign>
    <box>true</box>
  </label>

  <label>
    <name>Heading AP</name>
    <x>10</x>
    <y>80</y>
    <width>18</width>
    <height>10</height>
    <format>*</format>
    <halign>left</halign>
    <condition>
      <equals>
        <property>/autopilot/locks/heading</property>
        <value>dg-heading-hold</value>
      </equals>
    </condition>
  </label>

  <!--
================================================================================
                                                                           SPEED
================================================================================
-->
  <!-- ~~~~~~~~~~~~~~~~~~ airspeed -->
  <label>
    <name>KIAS</name>
    <x>-139</x>
    <y>30</y>
    <width>38</width>
    <height>10</height>
    <input>
      <property>/instrumentation/airspeed-indicator/true-speed-kt</property>
    </input>
    <format>%4.0fkt</format>
    <halign>right</halign>
    <box>true</box>
  </label>

  <label>
    <name>KIAS AP</name>
    <x>-100</x>
    <y>30</y>
    <width>38</width>
    <height>10</height>
    <format>*</format>
    <halign>left</halign>
    <condition>
      <equals>
        <property>/autopilot/locks/speed</property>
        <value>speed-with-throttle</value>
      </equals>
    </condition>
  </label>

  <!--
================================================================================
                                                                        ALTITUDE
================================================================================
-->

  <label>
    <name>vspeed</name>
    <x>109</x>
    <y>50</y>
    <width>36</width>
    <height>8</height>
    <input>
      <property>/autopilot/internal/vert-speed-fpm</property>
    </input>
    <format>VS %d fpm</format>
    <halign>right</halign>
    <box>false</box>
  </label>

  <label>
    <name>Altitude</name>
    <x>109</x>
    <y>30</y>
    <width>36</width>
    <height>10</height>
    <input>
      <property>/instrumentation/altimeter/indicated-altitude-ft</property>
    </input>
    <format>%6.0fft</format>
    <halign>right</halign>
    <box>true</box>
  </label>

  <label>
    <name>Altitude AP</name>
    <x>146</x>
    <y>30</y>
    <width>38</width>
    <height>10</height>
    <format>*</format>
    <halign>left</halign>
    <condition>
      <equals>
        <property>/autopilot/locks/altitude</property>
        <value>altitude-hold</value>
      </equals>
    </condition>
  </label>

  <label>
    <name>flight level</name>
    <x>109</x>
    <y>18</y>
    <width>36</width>
    <height>8</height>
    <input>
      <property>/instrumentation/altimeter/indicated-altitude-ft</property>
      <factor>0.01</factor>
    </input>
    <format>FL %3.0f</format>
    <halign>right</halign>
    <box>false</box>
    <condition>
      <greater-than>
        <property>/instrumentation/altimeter/indicated-altitude-ft</property>
        <value>5000</value>
      </greater-than>
    </condition>
  </label>

  <label>
    <name>ralt</name>
    <x>0</x>
    <y>-120</y>
    <halign>center</halign>
    <format>R %4.0fft</format>
    <input>
      <property>/position/altitude-agl-ft</property>
    </input>
    <condition>
      <less-than>
        <property>/position/altitude-agl-ft</property>
        <value>5000</value>
      </less-than>
      <less-than>
        <property>/orientation/roll-deg</property>
        <value>85</value>
      </less-than>
      <greater-than>
        <property>/orientation/roll-deg</property>
        <value>-85</value>
      </greater-than>
    </condition>
  </label>


  <!--
================================================================================
                                                                        COMMANDS
================================================================================
-->
  <!-- ~~~~~~~~~~~~~~~~~~ commands positions -->
  <gauge>
    <name>roll gauge</name>
    <x>-135</x>
    <y>-105</y>
    <width>35</width>
    <height>5</height>
    <option>top</option>
    <option>horizontal</option>
    <option>notext</option>
    <major-divisions>1</major-divisions>
    <minor-divisions>0</minor-divisions>
    <input>
      <property>/controls/flight/aileron</property>
      <max>1.0</max>
      <min>-1.0</min>
    </input>
  </gauge>

  <gauge>
    <name>pitch gauge</name>
    <x>-135</x>
    <y>-125</y>
    <width>10</width>
    <height>40</height>
    <option>vertical</option>
    <option>right</option>
    <option>notext</option>
    <major-divisions>1</major-divisions>
    <minor-divisions>0</minor-divisions>
    <input>
      <property>/controls/flight/elevator</property>
      <factor>-1</factor>
      <max>1.0</max>
      <min>-1.0</min>
    </input>
  </gauge>

  <gauge>
    <name>yaw gauge</name>
    <x>-135</x>
    <y>-108</y>
    <width>35</width>
    <height>3</height>
    <option>horizontal</option>
    <option>bottom</option>
    <option>notext</option>
    <major-divisions>1</major-divisions>
    <minor-divisions>0</minor-divisions>
    <input>
      <property>/controls/flight/rudder</property>
      <max>1.0</max>
      <min>-1.0</min>
    </input>
  </gauge>

  <!-- ~~~~~~~~~~~~~~~~~~ trim -->

  <label>
    <name>pitch trim value</name>
    <input>
      <property>/controls/flight/elevator-trim</property>
    </input>
    <x>-160</x>
    <y>-110</y>
    <width>10</width>
    <height>8</height>
    <halign>middle</halign>
    <format>%.3f</format>
  </label>

  <gauge>
    <name>pitch trim gauge</name>
    <x>-141</x>
    <y>-113</y>
    <width>5</width>
    <height>16</height>
    <option>vertical</option>
    <option>left</option>
    <option>notext</option>
    <major-divisions>1</major-divisions>
    <minor-divisions>0</minor-divisions>
    <input>
      <property>/controls/flight/elevator-trim</property>
      <factor>-2</factor>
      <max>1.0</max>
      <min>-1.0</min>
    </input>
  </gauge>

  <!-- ~~~~~~~~~~~~~~~~~~ throttles -->

  <gauge>
    <name>throttle0</name>
    <x>-95</x>
    <y>-125</y>
    <width>8</width>
    <height>40</height>
    <option>vertical</option>
    <option>left</option>
    <option>notext</option>
    <major-divisions>100</major-divisions>
    <input>
      <property>/controls/engines/engine[0]/throttle</property>
      <factor>100</factor>
      <max>100.0</max>
      <min>0.0</min>
    </input>
  </gauge>
  <gauge>
    <name>throttle1</name>
    <x>-95</x>
    <y>-125</y>
    <width>8</width>
    <height>40</height>
    <option>vertical</option>
    <option>right</option>
    <option>notext</option>
    <major-divisions>100</major-divisions>
    <input>
      <property>/controls/engines/engine[1]/throttle</property>
      <factor>100</factor>
      <max>100.0</max>
      <min>0.0</min>
    </input>
  </gauge>

  <!--
================================================================================
                                                                  AVIONICS INFOS
================================================================================
-->
  <!-- ~~~~~~~~~~~~~~~~~~ angle of attack -->
  <label>
    <name>AoA</name>
    <input>
      <property>/orientation/alpha-deg</property>
    </input>
    <x>-120</x>
    <y>-15</y>
    <width>30</width>
    <height>8</height>
    <halign>right</halign>
    <format>AoA %3.1f</format>
  </label>

  <tape>
    <name>aoa gauge</name>
    <x>-85</x>
    <y>-40</y>
    <width>10</width>
    <height>60</height>
    <option>right</option>
    <option>vertical</option>
    <label-gap-width>0</label-gap-width>
    <major-divisions>5</major-divisions>
    <minor-divisions>1</minor-divisions>
    <display-span>20</display-span>
    <tick-bottom>false</tick-bottom>
    <tick-top>false</tick-top>
    <tick-right>false</tick-right>
    <tick-left>false</tick-left>
    <cap-bottom>false</cap-bottom>
    <cap-top>false</cap-top>
    <cap-right>false</cap-right>
    <cap-left>false</cap-left>
    <marker-offset>3</marker-offset>
    <enable-pointer>true</enable-pointer>
    <pointer-type>fixed</pointer-type>
    <tick-type>line</tick-type>
    <tick-length>variable</tick-length>
    <input>
      <property>/orientation/alpha-deg</property>
      <factor>1</factor>
      <max>20.0</max>
      <min>-5.0</min>
    </input>
    <condition>
      <or>
        <greater-than>
          <property>/orientation/alpha-deg</property>
          <value>2.5</value>
        </greater-than>
        <and>
          <property>/controls/gear/gear-down</property>
          <greater-than>
            <property>/orientation/alpha-deg</property>
            <value>-1.2</value>
          </greater-than>
        </and>
      </or>
    </condition>
  </tape>

  <!-- ~~~~~~~~~~~~~~~~~~ gears -->
  <label>
    <name>Gear</name>
    <x>-56</x>
    <y>-120</y>
    <width>15</width>
    <height>6</height>
    <condition>
      <property>/controls/gear/gear-down</property>
    </condition>
    <format>gears</format>
    <halign>right</halign>
  </label>

  <!-- ~~~~~~~~~~~~~~~~~~ parking brake -->
  <label>
    <name>Parking Brake</name>
    <x>-56</x>
    <y>-112</y>
    <width>15</width>
    <height>6</height>
    <condition>
      <property>/controls/gear/brake-parking</property>
    </condition>
    <format>brake</format>
    <halign>right</halign>
  </label>

  <!-- ~~~~~~~~~~~~~~~~~~ speed brake -->
  <label>
    <name>Speed Brake</name>
    <input>
      <property>/controls/flight/speedbrake</property>
      <factor>10</factor>
    </input>
    <x>-56</x>
    <y>-104</y>
    <width>15</width>
    <height>6</height>
    <condition>
      <greater-than>
        <property>/controls/flight/speedbrake</property>
        <value>0</value>
      </greater-than>
    </condition>
    <format>spdbrk %1.0f</format>
    <halign>right</halign>
  </label>
  <!-- ~~~~~~~~~~~~~~~~~~ flaps -->
  <label>
    <name>Flaps</name>
    <input>
      <property>/controls/flight/flaps</property>
      <factor>10</factor>
    </input>
    <x>-56</x>
    <y>-96</y>
    <width>15</width>
    <height>6</height>
    <condition>
      <greater-than>
        <property>/controls/flight/flaps</property>
        <value>.1</value>
      </greater-than>
    </condition>
    <format>flaps %1.0f</format>
    <halign>right</halign>
  </label>

  <!-- ~~~~~~~~~~~~~~~~~~ G load -->
  <label>
    <name>G Load</name>
    <x>-120</x>
    <y>-80</y>
    <width>1.5</width>
    <height>1.5</height>
    <input>
      <property>/accelerations/pilot-g</property>
    </input>
    <format>%2.1fg</format>
    <halign>left</halign>
  </label>

  <!-- ~~~~~~~~~~~~~~~~~~ gear agl for landing -->
  <gauge>
    <name>touchdown</name>
    <x>-40</x>
    <y>-90</y>
    <width>12</width>
    <height>100</height>
    <option>vertical</option>
    <option>right</option>
    <option>notext</option>
    <major-divisions>15</major-divisions>
    <minor-divisions>5</minor-divisions>
    <input>
      <property>/position/gear-agl-ft</property>
      <factor>1</factor>
      <max>50.0</max>
      <min>0.0</min>
    </input>
    <condition>
      <property>/controls/gear/gear-down</property>
      <less-than>
        <property>/position/gear-agl-ft</property>
        <value>60</value>
      </less-than>
      <not><property>/gear/gear[0]/wow</property></not>
    </condition>
  </gauge>

  <!-- ~~~~~~~~~~~~~~~~~~ air to air refuelling -->
  <label>
    <name>aar</name>
    <x>0</x>
    <y>-40</y>
    <halign>center</halign>
    <format>AAR</format>
    <condition>
      <property>/systems/refuel/contact</property>
    </condition>
  </label>


  <!--
================================================================================
                                                               AVIONICS WARNINGS
================================================================================
-->

  <!-- ~~~~~~~~~~~~~~~~~~ altitude to low -->
  <label>
    <name>elevationWarn</name>
    <x>0</x>
    <y>40</y>
    <condition>
      <equals>
        <property>/controls/gear/gear-down</property>
        <value>false</value>
      </equals>
      <less-than>
        <property>/position/altitude-agl-ft</property>
        <value>300</value>
      </less-than>
      <less-than>
        <property>/instrumentation/vertical-speed-indicator/indicated-speed-kts</property>
        <value>0</value>
      </less-than>
    </condition>
    <halign>center</halign>
    <format>PULL UP ! %5.0fft</format>
    <input>
      <property>/position/altitude-agl-ft</property>
    </input>
    <blinking>
      <interval>0.25</interval>
    </blinking>
  </label>

  <!--
================================================================================
                                                                        NAV DATA
================================================================================
-->

<!-- ~~~~~~~~~~~~~~~~~~ GPS data if nav1 master and slaved to gps -->
  <label>
    <name>nav_data_gps_id</name>
    <x>40</x>
    <y>-95</y>
    <width>20</width>
    <height>6</height>
    <condition>
      <property>/instrumentation/nav[0]/slaved-to-gps</property>
    </condition>
    <format>GPS %s</format>
    <input>
      <property>/instrumentation/gps/wp/wp[1]/ID</property>
    </input>
    <halign>left</halign>
  </label>
  <label>
    <name>nav_data_gps_bearing</name>
    <x>40</x>
    <y>-105</y>
    <width>20</width>
    <height>6</height>
    <condition>
      <property>/instrumentation/nav[0]/slaved-to-gps</property>
    </condition>
    <format>%.0f deg</format>
    <input>
      <property>/instrumentation/gps/wp/wp[1]/bearing-true-deg</property>
    </input>
    <halign>left</halign>
  </label>
  <label>
    <name>nav_data_gps_eta</name>
    <x>40</x>
    <y>-115</y>
    <width>20</width>
    <height>6</height>
    <condition>
      <property>/instrumentation/nav[0]/slaved-to-gps</property>
    </condition>
    <format>eta %s</format>
    <input>
      <property>/instrumentation/gps/wp/wp[1]/TTW</property>
    </input>
    <halign>left</halign>
  </label>
  <label>
    <name>nav_data_gps_dist</name>
    <x>40</x>
    <y>-125</y>
    <width>20</width>
    <height>6</height>
    <condition>
      <property>/instrumentation/nav[0]/slaved-to-gps</property>
    </condition>
    <format>%.1f NM</format>
    <input>
      <property>/instrumentation/gps/wp/wp[1]/distance-nm</property>
    </input>
    <halign>left</halign>
  </label>

<!-- ~~~~~~~~~~~~~~~~~~ nav1 data if not slaved to gps -->
  <label>
    <name>nav_data_nav1_id</name>
    <x>40</x>
    <y>-95</y>
    <width>20</width>
    <height>6</height>
    <condition>
      <greater-than>
        <property>/instrumentation/nav[0]/signal-quality-norm</property>
        <value>0.4</value>
      </greater-than>
      <property>/instrumentation/nav[0]/serviceable</property>
      <not><property>/instrumentation/nav[0]/slaved-to-gps</property></not>
    </condition>
    <format>NAV1 %s</format>
    <input>
      <property>/instrumentation/nav[0]/nav-id</property>
    </input>
    <halign>left</halign>
  </label>
  <label>
    <name>nav_data_nav1_bearing</name>
    <x>40</x>
    <y>-105</y>
    <width>20</width>
    <height>6</height>
    <condition>
      <greater-than>
        <property>/instrumentation/nav[0]/signal-quality-norm</property>
        <value>0.4</value>
      </greater-than>
      <property>/instrumentation/nav[0]/serviceable</property>
      <not><property>/instrumentation/nav[0]/slaved-to-gps</property></not>
    </condition>
    <format>%.0f deg</format>
    <input>
      <property>/instrumentation/nav[0]/heading-deg</property>
    </input>
    <halign>left</halign>
  </label>
  <label>
    <name>nav_data_nav1_eta</name>
    <x>40</x>
    <y>-115</y>
    <width>20</width>
    <height>6</height>
    <condition>
      <greater-than>
        <property>/instrumentation/nav[0]/signal-quality-norm</property>
        <value>0.4</value>
      </greater-than>
      <property>/instrumentation/nav[0]/serviceable</property>
      <not><property>/instrumentation/nav[0]/slaved-to-gps</property></not>
    </condition>
    <format>eta %.0f min</format>
    <input>
      <property>/instrumentation/dme[0]/indicated-time-min</property>
    </input>
    <halign>left</halign>
  </label>
  <label>
    <name>nav_data_nav1_dist</name>
    <x>40</x>
    <y>-125</y>
    <width>20</width>
    <height>6</height>
    <condition>
      <greater-than>
        <property>/instrumentation/nav[0]/signal-quality-norm</property>
        <value>0.4</value>
      </greater-than>
      <property>/instrumentation/nav[0]/serviceable</property>
      <not><property>/instrumentation/nav[0]/slaved-to-gps</property></not>
    </condition>
    <format>%.1f NM</format>
    <input>
      <property>/instrumentation/dme[0]/indicated-distance-nm</property>
    </input>
    <halign>left</halign>
  </label>
  <label>
    <name>nav_data_nav1_kt</name>
    <x>40</x>
    <y>-135</y>
    <width>20</width>
    <height>6</height>
    <condition>
      <greater-than>
        <property>/instrumentation/nav[0]/signal-quality-norm</property>
        <value>0.4</value>
      </greater-than>
      <property>/instrumentation/nav[0]/serviceable</property>
      <not><property>/instrumentation/nav[0]/slaved-to-gps</property></not>
    </condition>
    <format>%.0f kt</format>
    <input>
      <property>/instrumentation/dme[0]/indicated-ground-speed-kt</property>
    </input>
    <halign>left</halign>
  </label>




<!--
================================================================================
                                                                       DEV TOOLS
================================================================================
-->

  <gauge>
    <name>debug elevator</name>
    <x>70</x>
    <y>-135</y>
    <width>10</width>
    <height>80</height>
    <option>vertical</option>
    <option>right</option>
    <option>notext</option>
    <input>
      <property>/controls/flight/elevator</property>
      <factor>-1</factor>
      <max>1.0</max>
      <min>-1.0</min>
    </input>
    <condition>
      <property>/_debug/show_devtools</property>
    </condition>
  </gauge>
  <gauge>
    <name>debug fcm-elevator</name>
    <x>80</x>
    <y>-135</y>
    <width>10</width>
    <height>80</height>
    <option>vertical</option>
    <option>right</option>
    <option>notext</option>
    <major-divisions>1</major-divisions>
    <minor-divisions>1</minor-divisions>
    <input>
      <property>/controls/flight/fdm-elevator</property>
      <factor>-1</factor>
      <max>1.0</max>
      <min>-1.0</min>
    </input>
    <condition>
      <property>/_debug/show_devtools</property>
    </condition>
  </gauge>

  <gauge>
    <name>debug elevator pos</name>
    <x>90</x>
    <y>-135</y>
    <width>10</width>
