<?xml version="1.0" encoding="utf-8"?>

<PropertyList>

  <filter>
    <type>gain</type>
    <gain>-1</gain>
    <input>/rendering/scene/diffuse/green</input>
    <reference>1</reference>
    <output>/sim/model/rendering/relative-navlight-luminosity</output>
    <min>.4</min>
    <max>1</max>
  </filter>
  <filter>
    <type>gain</type>
    <gain>2</gain>
    <input>/sim/model/rendering/relative-navlight-luminosity</input>
    <output>/sim/model/rendering/relative-strobelight-luminosity</output>
  </filter>
  <filter>
    <type>gain</type>
    <gain>.3</gain>
    <input>/sim/model/rendering/relative-navlight-luminosity</input>
    <output>/sim/model/rendering/relative-taxilight-luminosity</output>
    <min>.1</min>
    <max>1</max>
  </filter>

  <filter>
    <type>gain</type>
    <gain>-1</gain>
    <input>/rendering/scene/diffuse/green</input>
    <reference>1</reference>
    <output>/sim/model/rendering/relative-luminosity</output>
    <min>.1</min>
    <max>1</max>
  </filter>

  <filter>
    <type>gain</type>
    <input>
      <expression>
        <product>
          <property>/controls/light/cabin-norm</property>
          <property>/sim/model/rendering/relative-luminosity</property>
        </product>
      </expression>
    </input>
    <output>/sim/model/rendering/relative-cabin-luminosity</output>
  </filter>
  <filter>
    <type>gain</type>
    <gain>.9</gain>
    <input>
      <expression>
        <product>
          <property>/controls/light/instrument-norm</property>
          <property>/sim/model/rendering/relative-luminosity</property>
        </product>
      </expression>
    </input>
    <output>/sim/model/rendering/relative-instrument-luminosity</output>
  </filter>
  <filter>
    <type>gain</type>
    <input>
      <expression>
        <product>
          <property>/controls/light/panel-norm</property>
          <property>/sim/model/rendering/relative-luminosity</property>
        </product>
      </expression>
    </input>
    <output>/sim/model/rendering/relative-panel-luminosity</output>
  </filter>

  <filter>
    <type>gain</type>
    <gain>33.86389</gain>
    <input>/environment/pressure-sea-level-inhg</input>
    <output>/environment/pressure-sea-level-hpa</output>
  </filter>

  <!-- quand on a declenche un clic, ce filtre fait varier click-sound (float)
  entre 0 et 1, cela permet d'avoir un etat transitoire pour declencher le son
  -->
  <filter>
    <name>click</name>
    <type>noise-spike</type>
    <max-rate-of-change>7</max-rate-of-change>
    <input>sim/model/click</input>
    <output>sim/model/click-sound</output>
  </filter>

  <filter>
    <name>splash-x</name>
    <update-interval-secs type="double">0.1</update-interval-secs>
    <type>gain</type>
    <gain>1.0</gain>
    <input>
      <condition>
        <greater-than>
          <property>/environment/rain-norm</property>
          <value>0.1</value>
        </greater-than>
      </condition>
      <expression>
        <table>
          <property>/instrumentation/airspeed-indicator/true-speed-kt</property>
          <entry><ind>0</ind><dep>0.1</dep></entry>
          <entry><ind>5</ind><dep>0.9</dep></entry>
          <entry><ind>50</ind><dep>2</dep></entry>
          <entry><ind>100</ind><dep>3</dep></entry>
          <entry><ind>200</ind><dep>6</dep></entry>
        </table>
      </expression>
    </input>
    <output>
      <property>/environment/aircraft-effects/splash-vector-x</property>
    </output>
  </filter>

  <filter>
    <name>splash-z</name>
    <update-interval-secs type="double">0.1</update-interval-secs>
    <type>gain</type>
    <gain>1.0</gain>
    <input>
      <condition>
        <greater-than>
          <property>/environment/rain-norm</property>
          <value>0.1</value>
        </greater-than>
      </condition>
      <expression>
        <table>
          <property>/instrumentation/airspeed-indicator/true-speed-kt</property>
          <entry><ind>0</ind><dep>-0.8</dep></entry>
          <entry><ind>5</ind><dep>-1</dep></entry>
          <entry><ind>50</ind><dep>-2</dep></entry>
          <entry><ind>100</ind><dep>-3</dep></entry>
          <entry><ind>200</ind><dep>-4</dep></entry>
        </table>
      </expression>
    </input>
    <output>
      <property>/environment/aircraft-effects/splash-vector-z</property>
    </output>
  </filter>

  <logic>
    <name>volume_as_external</name>
    <input>
      <or>
        <and>
          <!-- view Nose and window opened -->
          <equals>
            <property>/sim/current-view/view-number-raw</property>
            <value>0</value>
          </equals>
          <greater-than>
            <property>/sim/model/door-positions/windows-position-norm</property>
            <value>0</value>
          </greater-than>
        </and>
        <and>
          <!-- view CoPilot and window opened -->
          <equals>
            <property>/sim/current-view/view-number-raw</property>
            <value>108</value>
          </equals>
          <greater-than>
            <property>/sim/model/door-positions/windows-position-norm</property>
            <value>0</value>
          </greater-than>
        </and>
        <and>
          <!-- view Pilot and window opened -->
          <equals>
            <property>/sim/current-view/view-number-raw</property>
            <value>107</value>
          </equals>
          <greater-than>
            <property>/sim/model/door-positions/windows-position-norm</property>
            <value>0</value>
          </greater-than>
        </and>
        <and>
          <!-- view NavigationDeck and door1 and bay opened -->
          <equals>
            <property>/sim/current-view/view-number-raw</property>
            <value>106</value>
          </equals>
          <or>
            <greater-than>
              <property>/sim/model/door-positions/windows-position-norm</property>
              <value>0</value>
            </greater-than>
            <and>
              <greater-than>
                <property>/sim/model/door-positions/door1-position-norm</property>
                <value>0</value>
              </greater-than>
              <greater-than>
                <property>/sim/model/door-positions/bay-position-norm</property>
                <value>0</value>
              </greater-than>
            </and>
          </or>
        </and>
        <and>
          <!-- view Bay and bay opened -->
          <equals>
            <property>/sim/current-view/view-number-raw</property>
            <value>105</value>
          </equals>
          <greater-than>
            <property>/sim/model/door-positions/bay-position-norm</property>
            <value>0</value>
          </greater-than>
        </and>
        <and>
          <!-- view Outside -->
          <equals>
            <property>/sim/current-view/view-number-raw</property>
            <value>104</value>
          </equals>
        </and>
        <and>
          <!-- view Bedroom and door2 and bay opened -->
          <equals>
            <property>/sim/current-view/view-number-raw</property>
            <value>103</value>
          </equals>
          <greater-than>
            <property>/sim/model/door-positions/door2-position-norm</property>
            <value>0</value>
          </greater-than>
          <greater-than>
            <property>/sim/model/door-positions/bay-position-norm</property>
            <value>0</value>
          </greater-than>
        </and>
        <and>
          <!-- view TopTurret and door2 and door3 and bay opened -->
          <equals>
            <property>/sim/current-view/view-number-raw</property>
            <value>102</value>
          </equals>
          <greater-than>
            <property>/sim/model/door-positions/door3-position-norm</property>
            <value>0</value>
          </greater-than>
          <greater-than>
            <property>/sim/model/door-positions/door2-position-norm</property>
            <value>0</value>
          </greater-than>
          <greater-than>
            <property>/sim/model/door-positions/bay-position-norm</property>
            <value>0</value>
          </greater-than>
        </and>
        <and>
          <!-- view Livingroom and door2 and door3 and bay opened -->
          <equals>
            <property>/sim/current-view/view-number-raw</property>
            <value>101</value>
          </equals>
          <greater-than>
            <property>/sim/model/door-positions/door3-position-norm</property>
            <value>0</value>
          </greater-than>
          <greater-than>
            <property>/sim/model/door-positions/door2-position-norm</property>
            <value>0</value>
          </greater-than>
          <greater-than>
            <property>/sim/model/door-positions/bay-position-norm</property>
            <value>0</value>
          </greater-than>
        </and>
        <not><property>/sim/current-view/internal</property></not>
      </or>
    </input>
    <output>/sim/sound/volume_as_external</output>
  </logic>

  <logic>
    <name>view-from-scale</name>
    <input>
      <equals>
        <property>/controls/doors/scale</property>
        <value>1</value>
      </equals>
    </input>
    <output>/sim/view[104]/enabled</output>
  </logic>

</PropertyList>



