<?xml version="1.0" encoding="utf-8"?>
<PropertyList>

  <path>als_light.ac</path>
  <nopreview />

  <effect>
    <inherits-from>procedural-light-nav-tail</inherits-from>
    <object-name>als_light</object-name>
  </effect>

  <animation>
    <type>select</type>
    <object-name>als_light</object-name>
    <condition>
      <property>/controls/light/nav</property>
      <equals><property>/systems/electrical/on</property><value>1</value></equals>
    </condition>
  </animation>

</PropertyList>
