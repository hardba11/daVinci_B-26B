<!-- ================================================= EQUIPEMENTS INTERIEUR -->

    <gear>
      <name>gear</name>
      <mode>in-transit</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_gear_down.wav</path>
      <condition>
        <property>/sim/current-view/internal</property>
        <greater-than>
          <property>/gear/gear[0]/position-norm</property>
          <value>0</value>
        </greater-than>
        <less-than>
          <property>/gear/gear[0]/position-norm</property>
          <value>1</value>
        </less-than>
      </condition>
    </gear>

    <flaps>
      <name>flaps</name>
      <mode>in-transit</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_flaps.wav</path>
      <property>/surface-positions/flap-pos-norm</property>
      <volume>
        <factor>0.3</factor>
      </volume>
      <pitch>
        <min>0.4</min>
        <max>0.4</max>
      </pitch>
    </flaps>

    <speedbrakes>
      <name>speedbrakes</name>
      <mode>in-transit</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_speedbrakes.wav</path>
      <property>/surface-positions/speedbrake-pos-norm</property>
      <volume>
        <factor>0.3</factor>
      </volume>
    </speedbrakes>

    <canopy-open>
      <name>canopy slide open</name>
      <path>Aircraft/daVinci_B-26B/sounds/b26_canopy.wav</path>
      <condition>
        <property>/sim/current-view/internal</property>
        <greater-than>
          <property>/sim/model/door-positions/windows-position-norm</property>
          <value>0.1</value>
        </greater-than>
      </condition>
      <volume>
        <factor>0.7</factor>
      </volume>
    </canopy-open>

    <canopy-close>
      <name>canopy slide close</name>
      <path>Aircraft/daVinci_B-26B/sounds/b26_canopy.wav</path>
      <condition>
        <property>/sim/current-view/internal</property>
        <less-than>
          <property>/sim/model/door-positions/windows-position-norm</property>
          <value>0.3</value>
        </less-than>
      </condition>
      <volume>
        <factor>0.9</factor>
      </volume>
    </canopy-close>

    <baydoors>
      <name>baydoors</name>
      <mode>in-transit</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_baydoors.wav</path>
      <property>/sim/model/door-positions/bay-position-norm</property>
      <volume>
        <factor>0.4</factor>
      </volume>
    </baydoors>

    <click>
      <name>clic</name>
      <path>Sounds/click.wav</path>
      <mode>once</mode>
      <condition>
        <property>/sim/current-view/internal</property>
        <greater-than>
          <property>/sim/model/click-sound</property>
          <value type="float">.1</value>
        </greater-than>
        <less-than>
          <property>/sim/model/click-sound</property>
          <value type="float">.9</value>
        </less-than>
      </condition>
      <volume>
        <factor>0.2</factor>
      </volume>
    </click>

<!-- ========================================================= ENVIRONNEMENT -->

    <wind-doors-opened>
      <name>wind</name>
      <mode>looped</mode>
      <path>Aircraft/daVinci_B-26B/sounds/flux.wav</path>
      <condition>
        <property>/sim/sound/volume_as_external</property>
        <property>/sim/current-view/internal</property>
      </condition>
      <volume>
        <property>/velocities/airspeed-kt</property>
        <factor>0.01</factor>
        <min>0.0</min>
        <max>0.60</max>
        <offset>-0.12</offset>
      </volume>
    </wind-doors-opened>

    <rumble>
      <name>rumble</name>
      <mode>looped</mode>
      <path>Sounds/rumble.wav</path>
      <condition>
        <property>/sim/current-view/internal</property>
        <or>
          <property>/gear/gear[0]/wow</property>
          <property>/gear/gear[1]/wow</property>
          <property>/gear/gear[2]/wow</property>
        </or>
      </condition>
      <volume>
        <property>/gear/gear[1]/rollspeed-ms</property>
        <factor>0.015</factor>
      </volume>
    </rumble>

    <bruits-aerodynamiques-int>
      <name>bruits-aerodynamiques-int</name>
      <path>Aircraft/daVinci_B-26B/sounds/rumble.wav</path>
      <mode>looped</mode>
      <condition>
        <property>/sim/current-view/internal</property>
      </condition>
      <volume>
        <property>/velocities/airspeed-kt</property>
        <factor>0.0012</factor>
        <min>0</min>
        <max>0.8</max>
      </volume>
      <pitch>
        <property>/velocities/airspeed-kt</property>
        <factor>0.0009</factor>
        <min>0</min>
        <max>1.8</max>
      </pitch>
    </bruits-aerodynamiques-int>

    <rain-int>
      <name>rain-int</name>
      <path>Aircraft/daVinci_B-26B/sounds/rain-windshield.wav</path>
      <mode>looped</mode>
      <condition>
        <greater-than>
          <property>/environment/rain-norm</property>
          <value>0.1</value>
        </greater-than>
      </condition>
      <volume>
        <property>/environment/rain-norm</property>
        <factor>0.5</factor>
        <min>0.2</min>
        <max>1.5</max>
      </volume>
      <pitch>
        <property>/velocities/mach</property>
        <factor>0.6</factor>
        <min>0.2</min>
        <max>2</max>
      </pitch>
      <position>
        <x>-4.0</x>
        <y>0.0</y>
        <z>0.0</z>
      </position>
      <orientation>
        <x>-1.0</x>
        <y>0.0</y>
        <z>0.0</z>
        <inner-angle>3.0</inner-angle>
        <outer-angle>45.0</outer-angle>
        <outer-gain>0.9</outer-gain>
      </orientation>
    </rain-int>

    <rain-ext>
      <name>rain-ext</name>
      <path>Aircraft/daVinci_B-26B/sounds/rain.wav</path>
      <mode>looped</mode>
      <condition>
        <greater-than>
          <property>/environment/rain-norm</property>
          <value>0.1</value>
        </greater-than>
        <property>/sim/sound/volume_as_external</property>
      </condition>
      <volume>
        <min>0.2</min>
        <max>0.4</max>
      </volume>
    </rain-ext>

