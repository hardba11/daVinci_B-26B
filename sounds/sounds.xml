<?xml version="1.0" encoding="UTF-8"?>

<PropertyList>
  <fx>

<!-- =============================================== MOTEURS START EXTERIEUR -->

    <starterR-ext>
      <name>starterR-ext</name>
      <path>Aircraft/daVinci_B-26B/sounds/b26_engine_start.wav</path>
      <mode>looped</mode>
      <condition>
        <property>/engines/engine[0]/cranking</property>
        <property>/sim/sound/volume_as_external</property>
      </condition>
      <volume>
        <min>1.8</min>
        <max>1.8</max>
      </volume>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </starterR-ext>

    <starterL-ext>
      <name>starterL-ext</name>
      <path>Aircraft/daVinci_B-26B/sounds/b26_engine_start.wav</path>
      <mode>looped</mode>
      <condition>
        <property>/engines/engine[1]/cranking</property>
        <property>/sim/sound/volume_as_external</property>
      </condition>
      <volume>
        <min>1.8</min>
        <max>1.8</max>
      </volume>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </starterL-ext>

    <crankR-ext>
      <name>crankR-ext</name>
      <mode>once</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_engine_start.wav</path>
      <condition>
        <not><property>/engines/engine[0]/running</property></not>
        <property>/engines/engine[0]/cranking</property>
        <property>/sim/sound/volume_as_external</property>
      </condition>
      <volume>
        <min>1.8</min>
        <max>1.8</max>
      </volume>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </crankR-ext>

    <crankL-ext>
      <name>crankL-ext</name>
      <mode>once</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_engine_start.wav</path>
      <condition>
        <not><property>/engines/engine[1]/running</property></not>
        <property>/engines/engine[1]/cranking</property>
        <property>/sim/sound/volume_as_external</property>
      </condition>
      <volume>
        <min>1.8</min>
        <max>1.8</max>
      </volume>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </crankL-ext>

<!-- ================================================ MOTEURS STOP EXTERIEUR -->

    <shutdownR-ext>
      <name>shutdownR-ext</name>
      <mode>once</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_shutdown.wav</path>
      <condition>
        <!--property>/engines/engine[0]/shutdown</property-->
        <property>/sim/sound/volume_as_external</property>
        <less-than>
          <property>/engines/engine[0]/rpm</property>
          <value>200</value>
        </less-than>
      </condition>
      <volume>
        <min>1.8</min>
        <max>1.8</max>
      </volume>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </shutdownR-ext>

    <shutdownL-ext>
      <name>shutdownL-ext</name>
      <mode>once</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_shutdown.wav</path>
      <condition>
        <!--property>/engines/engine[1]/shutdown</property-->
        <property>/sim/sound/volume_as_external</property>
        <less-than>
          <property>/engines/engine[1]/rpm</property>
          <value>200</value>
        </less-than>
      </condition>
      <volume>
        <min>1.8</min>
        <max>1.8</max>
      </volume>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </shutdownL-ext>

<!-- ===================================================== MOTEURS EXTERIEUR -->

    <engineR-ext>
      <name>engineR-ext</name>
      <mode>looped</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_idle_rpm.wav</path>
      <condition>
        <property>/sim/sound/volume_as_external</property>
        <property>/engines/engine[0]/running</property>
        <less-than>
          <property>/engines/engine[0]/rpm</property>
          <value>2300</value>
        </less-than>
        <greater-than>
          <property>/engines/engine[0]/rpm</property>
          <value>200</value>
        </greater-than>
      </condition>
      <volume>
        <property>/engines/engine[0]/rpm</property>
        <min>1</min>
        <max>2</max>
        <factor>0.0004</factor>
      </volume>
      <pitch>
        <property>/engines/engine[0]/rpm</property>
        <min>0</min>
        <max>2</max>
        <offset>0.1</offset>
        <factor>0.0015</factor>
      </pitch>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </engineR-ext>

    <engineL-ext>
      <name>engineL-ext</name>
      <mode>looped</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_idle_rpm.wav</path>
      <condition>
        <property>/sim/sound/volume_as_external</property>
        <property>/engines/engine[1]/running</property>
        <less-than>
          <property>/engines/engine[1]/rpm</property>
          <value>2300</value>
        </less-than>
        <greater-than>
          <property>/engines/engine[1]/rpm</property>
          <value>200</value>
        </greater-than>
      </condition>
      <volume>
        <property>/engines/engine[1]/rpm</property>
        <min>1</min>
        <max>2</max>
        <factor>0.0004</factor>
      </volume>
      <pitch>
        <property>/engines/engine[1]/rpm</property>
        <min>0</min>
        <max>2</max>
        <offset>0.1</offset>
        <factor>0.0015</factor>
      </pitch>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </engineL-ext>

<!-- ===================================================== HELICES EXTERIEUR -->

    <propellerR-ext>
      <name>propellerR-ext</name>
      <mode>looped</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_high_rpm.wav</path>
      <condition>
        <property>/sim/sound/volume_as_external</property>
        <property>/engines/engine[0]/running</property>
        <greater-than>
          <property>/engines/engine[0]/rpm</property>
          <value>500</value>
        </greater-than>
      </condition>
      <volume>
        <property>/engines/engine[0]/rpm</property>
        <min>1</min>
        <max>2</max>
        <offset>-0.2</offset>
        <factor>0.0002</factor>
      </volume>
      <pitch>
        <property>/engines/engine[0]/rpm</property>
        <min>0</min>
        <max>2</max>
        <offset>0.5</offset>
        <factor>0.0006</factor>
      </pitch>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </propellerR-ext>

    <propellerL-ext>
      <name>propellerL-ext</name>
      <mode>looped</mode>
      <path>Aircraft/daVinci_B-26B/sounds/b26_high_rpm.wav</path>
      <condition>
        <property>/sim/sound/volume_as_external</property>
        <property>/engines/engine[1]/running</property>
        <greater-than>
          <property>/engines/engine[1]/rpm</property>
          <value>500</value>
        </greater-than>
      </condition>
      <volume>
        <property>/engines/engine[1]/rpm</property>
        <min>1</min>
        <max>2</max>
        <offset>-0.2</offset>
        <factor>0.0002</factor>
      </volume>
      <pitch>
        <property>/engines/engine[1]/rpm</property>
        <min>0</min>
        <max>2</max>
        <offset>0.5</offset>
        <factor>0.0006</factor>
      </pitch>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </propellerL-ext>

<!-- =========================================== CRISSEMENTS PNEUS EXTERIEUR -->

    <squeal>
      <name>squeal</name>
      <path>Sounds/squeal.wav</path>
      <condition>
        <or>
          <property>/gear/gear[0]/wow</property>
          <property>/gear/gear[1]/wow</property>
          <property>/gear/gear[2]/wow</property>
        </or>
        <greater-than>
          <property>/velocities/airspeed-kt</property>
          <value>10</value>
        </greater-than>
      </condition>
      <volume>
        <property>/velocities/speed-down-fps</property>
        <factor>0.3</factor>
        <max>1.0</max>
      </volume>
      <volume>
        <property>/velocities/airspeed-kt</property>
        <factor>0.01</factor>
        <max>1.0</max>
      </volume>
      <volume>
        <internal>dt_stop</internal>
        <factor>0.05</factor>
        <max>1.0</max>
      </volume>
      <pitch>
        <property>/velocities/airspeed-kt</property>
        <factor>0.0025</factor>
        <offset>1.2</offset>
      </pitch>
      <reference-dist>50</reference-dist>
      <max-dist>1200</max-dist>
    </squeal>


